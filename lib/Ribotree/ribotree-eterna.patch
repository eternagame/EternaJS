+"""arnie.mfe — MFE structure prediction via EternaJS bridge."""
+
+try:
+    import eternajs as _eternajs
+    _has_eternajs = True
+except ImportError:
+    _has_eternajs = False
+
+
+async def mfe(sequence, package='vienna', constraint=None, viterbi=False,
+        linear=False, return_dG_MFE=False, param_file=None, T=37, **kwargs):
+    """
+    Minimum free energy structure prediction via EternaJS folding engine bridge.
+
+    Returns:
+        - If return_dG_MFE=False: dot-bracket structure string
+        - If return_dG_MFE=True: tuple of (structure string, dG float)
+    """
+    if not _has_eternajs:
+        raise RuntimeError(
+            "arnie.mfe requires the EternaJS bridge. "
+            "Call pyodide.registerJsModule('eternajs', bridge) before importing ribotree."
+        )
+
+    result = await _eternajs.mfe(sequence, package)
+    result_dict = result.to_py() if hasattr(result, 'to_py') else dict(result)
+    structure = result_dict.get('structure', '.' * len(sequence))
+    energy = result_dict.get('energy', 0.0)
+
+    if return_dG_MFE:
+        return structure, energy
+    return structure
