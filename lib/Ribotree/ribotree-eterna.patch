@@ -0,0 +1,39 @@
+"""arnie.bpps — Base pair probability calculation via EternaJS bridge."""
+
+import numpy as np
+
+try:
+    import eternajs as _eternajs
+    _has_eternajs = True
+except ImportError:
+    _has_eternajs = False
+
+
+async def bpps(sequence, package='vienna', param_file=None, linear=False, T=37, **kwargs):
+    """
+    Base pair probability matrix via EternaJS folding engine bridge.
+
+    Returns:
+        numpy.ndarray of shape (N, N) with base pair probabilities.
+    """
+    if not _has_eternajs:
+        raise RuntimeError(
+            "arnie.bpps requires the EternaJS bridge. "
+            "Call pyodide.registerJsModule('eternajs', bridge) before importing ribotree."
+        )
+
+    result = await _eternajs.bpps(sequence, package)
+    result_dict = result.to_py() if hasattr(result, 'to_py') else dict(result)
+    probs = result_dict.get('probabilities', [])
+    length = result_dict.get('length', len(sequence))
+
+    matrix = np.zeros((length, length))
+    idx = 0
+    for i in range(length):
+        for j in range(i, length):
+            if idx < len(probs):
+                matrix[i, j] = probs[idx]
+                matrix[j, i] = probs[idx]
+                idx += 1
+
+    return matrix
