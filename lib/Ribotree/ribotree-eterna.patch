+"""arnie.free_energy — Free energy calculation via EternaJS bridge."""
+
+try:
+    import eternajs as _eternajs
+    _has_eternajs = True
+except ImportError:
+    _has_eternajs = False
+
+
+def free_energy(sequence, package='eternafold', constraint=None, T=37,
+                linear=False, param_file=None, **kwargs):
+    """
+    Free energy calculation via EternaJS folding engine bridge.
+
+    Args:
+        constraint: Optional dot-bracket structure for constrained evaluation.
+                    If None, returns the MFE (unconstrained) free energy.
+    """
+    if not _has_eternajs:
+        raise RuntimeError(
+            "arnie.free_energy requires the EternaJS bridge. "
+            "Call pyodide.registerJsModule('eternajs', bridge) before importing ribotree."
+        )
+
+    if constraint is None:
+        result = _eternajs.mfe(sequence, package)
+        result_dict = result.to_py() if hasattr(result, 'to_py') else dict(result)
+        return result_dict.get('energy', 0.0)
+
+    result = _eternajs.freeEnergy(sequence, constraint, package)
+    return float(result) if result else 0.0
